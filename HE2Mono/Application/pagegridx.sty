        \invisiblerule{0.1\p@}{\headheight}}%
      % Top grid rule
      \put(\strip@pt\pg@left,\strip@pt\pg@top){%
        \invisiblerule{\textwidth+\textgluewidth}{0.1\p@}}%
      % Left grid rule
      \put(\strip@pt\pg@left,\strip@pt\pg@bottom){%
        \invisiblerule{0.1\p@}{\textheight}}%
      % Right grid rule
      \put(\strip@pt\pg@right,\strip@pt\pg@bottom){%
        \invisiblerule{0.1\p@}{\textheight}}%
      \special{color pop}
      % Text baseline rule
      \setcounter{pg@linenumber}{1}
      \ifodd\arabic{page}%
        \multiput(\strip@pt\pg@left,\strip@pt\pg@firstline)%
                 (0,-\strip@pt\pg@bls){\thepg@numlines}{%
          \invisiblerule{\textwidth}{0.05\p@}%
          \hspace{-1.5pc}\hspace{\textgluewidth}\hspace{4pt}\pg@numps
	    \fontfamily{\default@family}%
	    \fontseries{\default@series}%
	    \fontshape{\default@shape}%
            \selectfont
            \rlap{\char32}%
          {\invisibletext{\pad@double@digit{pg@linenumber}}}%
          \stepcounter{pg@linenumber}}%
      \else
        \multiput(\strip@pt\pg@left,\strip@pt\pg@firstline)%
                 (0,-\strip@pt\pg@bls){\thepg@numlines}{%
          {\invisiblerule{\textwidth}{0.05\p@}}%
          \hspace{-\textgluewidth}\hspace{4pt}\hspace{\textwidth}\pg@numps
	    \fontfamily{\default@family}%
	    \fontseries{\default@series}%
	    \fontshape{\default@shape}%
            \selectfont
            \char32\invisibletext{\pad@double@digit{pg@linenumber}}%
          \stepcounter{pg@linenumber}}%
      \fi
      % Bottom grid rule
      \special{color push rgb 0 0.7 1}%
      \put(\strip@pt\pg@left,\strip@pt\pg@bottom){%
        \invisiblerule{\textwidth+\textgluewidth}{0.1\p@}}%
