\usepackage{soul}

\def\spreadoutfactor{1}

\def\spreadout#1{%
  \gdef\temp{#1}\dimen0 = \spreadoutfactor pt
  \expandafter\dospreadout\temp\endmark}

\def\dospreadout{%
  \afterassignment\findospreadout
  \let\next= }

\def\findospreadout{%
   \ifx\next\endmark
      \let\nextaction = \relax
   \else
      \let\nextaction = \dospreadout
      \next
      \kern\dimen0
\fi
   \nextaction}
\def\endmark{endmark}

