%%%match the width of fig cap with its figure width(narrow box figure)
\newbox\fibox
\newenvironment{nboxfig}[2]{\begin{center}
\sbox\fibox{#1}
\begin{minipage}{\wd\fibox}
\usebox\fibox
\captionof{figure}{#2}
}{\end{minipage}\end{center}}
%%
%%normal figure in text
%%
\def\nfig#1#2{
\sbox0{#1}
\centering
\begin{minipage}{\wd0}
\usebox0
#2
\end{minipage}}
%%%
