%%
%%%%%%%% Unnumberd References %%%%%%%%%%%
\setlength\bibleftmargin  {9.5\p@}
\setlength\bibitemsep  {\z@}
\setlength\bibparsep  {\z@}

%%%%%%%% Numbered Within Square Bracket %%%%%%%%%%%
