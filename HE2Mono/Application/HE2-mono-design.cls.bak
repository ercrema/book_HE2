\long\def\@makecaption#1#2{%
\vskip-7pt
\figcaptionfont
  \vskip\abovecaptionskip
  \sbox\@tempboxa{{\figcaptionnumfont#1}\enskip{\figcaptionfont #2}}%
  \ifdim \wd\@tempboxa >\hsize
   {\figcaptionnumfont#1}\enskip{\figcaptionfont #2}\par
  \else
    \global \@minipagefalse
    \hb@xt@\hsize{\figcaptionfont\box\@tempboxa\hfill}%
  \fi
  \vskip\belowcaptionskip}
%%%
\long\def\@SCmakecaption#1#2{%
\figcaptionfont
  \vskip\abovecaptionskip
  \sbox\@tempboxa{{\figcaptionnumfont#1}\enskip{\figcaptionfont #2}}%
  \ifdim \wd\@tempboxa >\hsize
   {\figcaptionnumfont#1}\enskip{\figcaptionfont #2}\par
  \else
    \global \@minipagefalse
    \hb@xt@\hsize{\figcaptionfont\box\@tempboxa\hfill}%
  \fi
  \vskip\belowcaptionskip}
