% Macro to be used to set table caption and footnotes to the size of the table.
% TODO: Remove this and integrate threeparttable.sty
\newcommand{\@processtable}[4]{%
  \hbox to \hsize{\hfil\begin{minipage}[t]{#4}%
  \color{black}
  \caption{#1}%
  {\fontsize{9}{12}\selectfont#2}\par%
  \@ifmtarg{#3}{}{\ifx\empty\vspace*{-13.5pt}\else\vspace{\tababovefootskip}
  \fontsize{9}{12}\selectfont#3\vspace*{-12.5pt}\strut\par\fi}%
\end{minipage}\hfil}}

