\renewenvironment{thebibliography}[1]
      {\global\bibliotoctrue%
      \bibliofont%
%       \ifAJW@appendix%
         \chapter*{\refname}%
         \if@mainmatter
         \addcontentsline{toc}{section}{\textit{\refname}}
         \else
         \fi
\markright{\refname}
\columnsep 15pt
\begin{multicols}{2}
       \def\@tempa{#1}%%%%%
         \ifx\@tempa\@empty%%%
          \bibliofont
          \list{}%
           {\labelwidth0pt\labelsep0pt
           \leftmargin\bibleftmargin%12
           \itemindent-\bibleftmargin
           \itemsep\bibitemsep
           \parsep\bibparsep
           \usecounter{enumiv}%
           \let\p@enumiv\@empty
           \renewcommand\theenumiv{\arabic{enumiv}}}%
      \else
     \setbox\tempbox\hbox{\bibliofont[\@tempa]}
    \tempdimen\wd\tempbox%%%\bibtempdimen\wd\bibtempbox
          \ifnumsquare
          \else
             \def\@biblabel##1{{\hbox to \tempdimen{\hss[##1]}}}%
          \fi%
           \bibliofont
           \list{\@biblabel{\arabic{enumiv}}}%
           {\settowidth\labelwidth{\@biblabel{#1}}%
           \labelsep6.5pt\leftmargin\labelsep
           \advance\leftmargin\labelwidth
           \itemindent0pt
           \itemsep\bibitemsep
           \parsep\bibparsep
           \usecounter{enumiv}%
           \let\p@enumiv\@empty
           \renewcommand\theenumiv{\arabic{enumiv}}}%
     \fi
     \sloppy\clubpenalty10000\widowpenalty10000%
     \sfcode`\.=\@m
    \let\citeN\cite \let\shortcite\cite
    \let\citeasnoun\cite
}
     {\def\@noitemerr
     {\@latex@warning{Empty `thebibliography' environment}}%
     \endlist%
     \end{multicols}
     \global\bibliotocfalse}%
