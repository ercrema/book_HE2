}


% Initializes TeX's marks
%
\mark{{}{}}
%
% centred \ps@plain and \ps@empty defined in LATEX.TEX
%
\ifAJW@indentsty
  \def\ps@plain{\let\@mkboth=\@gobbletwo
    \def\@oddfoot {\fontsize{9.5}{9.5}\selectfont\fontspec{FrutigerLTStd-Bold.otf}\hfill{\thepage}}
    \def\@evenfoot{\fontsize{9.5}{9.5}\selectfont\fontspec{FrutigerLTStd-Bold.otf}{\thepage}\hfill}
    \def\@oddhead {}
    \def\@evenhead{}}
\else
  \def\ps@plain{\leftskip\z@\let\@mkboth\@gobbletwo\vfuzz=5\p@
    \def\@oddhead{}%
    \def\@evenhead{}%
    \def\@oddfoot {\fontsize{9.5}{9.5}\selectfont\fontspec{FrutigerLTStd-Bold.otf}\hfill{\thepage}}
    \def\@evenfoot{\fontsize{9.5}{9.5}\selectfont\fontspec{FrutigerLTStd-Bold.otf}{\thepage}\hfill}
    \def\sectionmark##1{}%
    \def\subsectionmark##1{}%
 }
\fi



%
% Definition of 'headings' page style
%
\newlength\textwidthplus
\setlength\textwidthplus{\textwidth}
  \advance\textwidthplus\threepica
%
\newcommand\@greyrunningheadrule{%
\setlength\fboxsep{1\p@}%
  \def\FrameCommand{\hspace*{-3pc}\colorbox{scolor}}%
  \parindent0pt%
% frame needs to be \hsize + 3pc - 2x \fboxsep
  \MakeFramed{%
    \advance\hsize-\width
    \advance\hsize\threepica
    \advance\hsize-2\fboxsep
    \@parboxrestore
    }%
  \endMakeFramed
}

\newcommand\@insertgreyrunningheadrule{%
  {\parindent0pt\par\vbox to .5pt{%
    \hbox to\textwidthplus{%
      \vbox{\@greyrunningheadrule}%
    }\par
  }}%
}


\def\oddfolio{{\foliofont\thepage}}
\def\evenfolio{{\foliofont\thepage}}


\def\LRH#1{\gdef\@LRH{#1}}\LRH{\leftmark}
\def\RRH#1{\gdef\@RRH{#1}}\RRH{\rightmark}

\def\ps@headings{%
 \let\@mkboth=\markboth
    \let\@oddfoot\@empty
    \let\@evenfoot\@empty
    \def\@evenhead{%
       \vbox{\hbox to \textwidth{\hbox{\rlap{\hskip-3pc\evenfolio}{\hskip-.2\p@\rhfont
\if@mainmatter
\leftmark
\else
\ifAJW@appendix
Appendix \thechapter: \leftmark\fi
\@chaptext \fi\vphantom{gpq}} \hfill}}}}%
    \def\@oddhead{%
       \vbox{%
	 \hbox to
\textwidth{\hfill\lower.5\p@\hbox{\rhfont\rightmark\vphantom{gpq}}\hbox to 3pc{\hfill{\oddfolio}}}}}%
  \def\chaptermark##1{\markboth{##1}{##1}}
  \def\sectionmark##1{\markright{\ifnum \c@secnumdepth >\z@
   \thesection\hspace{0.5em}\fi ##1}}%
}%

%%
\def\ps@empty{
    \def\@oddfoot {}
    \def\@evenfoot{}
    \def\@oddhead {}
    \def\@evenhead{}}
%%%
\def\ps@appheadings{%
 \let\@mkboth=\markboth
    \let\@oddfoot\@empty
    \let\@evenfoot\@empty
    \def\@evenhead{%
       \vbox{%
	 \hbox to
\textwidth{\hbox{\rlap{\hskip-3pc\evenfolio}{\hskip-.2\p@\rhfont
\if@mainmatter
\@chaptext
\else \ifAJW@appendix
Appendix \thechapter: \@chaptext\fi
\@chaptext \fi\vphantom{gpq}} \hfill}}\vskip4.5\p@
	 \hbox{\hskip-3pc\special{color push cmyk 0,0,0,.3}\vrule
height2pt width36pc depth0pt\special{color pop}}
       }}%
    \def\@oddhead{%
       \vbox{%
	 \hbox to
\textwidth{\hfill\lower.5\p@\hbox{\rhfont\rightmark\vphantom{gpq}}\hbox
to 3pc{\hfill{\oddfolio}}}\vskip4.5\p@
	 \hbox{\hskip-3pc\special{color push cmyk 0,0,0,.3}\vrule
height2pt width36pc depth0pt\special{color pop}}
       }}%
 \ifAJW@multisty
  \def\chaptermark##1{\markboth{##1}{##1}}
  \def\sectionmark##1{\markright{\ifnum \c@secnumdepth >\z@
   \thesection\hspace{0.5em}\fi ##1}}%
}%

%
% Definition of 'myheadings' page style.
%
\def\ps@myheadings{\let\@mkboth=\@gobbletwo
 \def\@oddfoot {}
 \def\@evenfoot{}
 \def\@oddhead{%
   \hbox to \textwidth{\hfil{\rightmark}\hspace*{3pc}%
     \llap{\runningheadsize\lightseriffont\thepage}}%
   \hspace*{-\textwidth}{\@insertgreyrunningheadrule}%
 }%
 \def\@evenhead{\hspace*{-3pc}\hbox to 3pc{%
   \runningheadsize\lightseriffont\thepage\hfil}%
   \hbox to \textwidthplus{%
     {
       {\leftmark}\hfil}}%
     \hspace*{-\textwidthplus}{\@insertgreyrunningheadrule}%
 }%
 \def\chaptermark##1{}
 \def\sectionmark##1{}
 \def\subsectionmark##1{}}


