            \vss
            \normalfont
            \normalsize
            \expandafter\csname\CROP@font\endcsname{%
                               \hfil\jobname\qquad CUP/HE2-design\qquad \today\quad \CROP@time \quad\qquad Page-{\bf \thepage}
                \strut
            \hfil}%
            \vskip\dimen@
        }%
        \hss
    }%
}}

