\newdimen\@chpmax
\newdimen\@sectmax
\newbox\tocsubsecbox
\newdimen\@subsectmax
\newdimen\tocsecnum
\newdimen\tocsectotal
\newdimen\tocsubsecnum
\newdimen\tocsubsectotal
\newdimen\tocsubsubsecnum
\newdimen\tocsubsubsectotal
\newdimen\tocparanum
\newdimen\tocparatotal
\newdimen\tocsubparanum
%
\def\chpmax#1{\global\setbox\tocchapbox\hbox{\bfseries #1}%
    \@chpmax\wd\tocchapbox}%

\def\sectmax#1{\global\setbox\tocsecbox\hbox{\bfseries #1\enspace}%
       \@sectmax\wd\tocsecbox}

\def\subsectmax#1{\global\setbox\tocsubsecbox\hbox{\bfseries #1\enspace}%
    \@subsectmax\wd\tocsubsecbox
}%
\settowidth{\tocchpnum}{13\enspace\qquad}
\settowidth{\tocsecnum}{13.6\enspace\qquad}
\settowidth{\tocsubsecnum}{19.8.7\enspace\qquad}
%
\def\calctocindent{%
\tocsectotal=\tocchpnum
\advance\tocsectotal by\tocsecnum
\tocsubsectotal=\tocsectotal
\advance\tocsubsectotal by\tocsubsecnum
\tocsubsubsectotal=\tocsubsectotal
\advance\tocsubsubsectotal by\tocsubsubsecnum
\tocparatotal=\tocsubsubsectotal
\advance\tocparatotal by\tocparanum}
\calctocindent
\renewcommand\@pnumwidth{3pc}%
%
\newcommand*\l@part[2]{\vspace{\baselineskip}%
 \addpenalty{-\@highpenalty}%
 \begingroup
  \rightskip \@pnumwidth
  \parfillskip -\@pnumwidth
  \leavevmode%
  %\ifAJW@multisty \else \hspace*{\AJW@toclmarg}\fi
  \ifAJW@firstTOCentry
    {\hspace*{-1pc}\fontspec{FrutigerLTStd-BoldCn.otf}\fontsize{12}{14}\selectfont #1} \hfil \hbox to\@pnumwidth{\hss {\normalfont\itshape page\/} {#2}}\par
    \global\AJW@firstTOCentryfalse
  \else
    {\hspace*{-1pc}\fontspec{FrutigerLTStd-BoldCn.otf}\fontsize{12}{14}\selectfont #1} \hfil \hbox to\@pnumwidth{\hss {#2}}\par%
  \fi
  \vspace*{-7pt}
  \nobreak
  \endgroup
}

\newcommand*\l@chapter[2]{\pagebreak[3]
 \addvspace{\baselineskip}%
 \@tempdima \@chpmax%
 \begingroup%
  \parindent 0pc%\z@
    \rightskip \@pnumwidth  \parfillskip -\@pnumwidth%
  \leavevmode%
  \advance\rightskip by \z@ \@plus 2cm%
  \ifAJW@firstTOCentry%
   {\normalfont\fontspec{FrutigerLTStd-BoldCn.otf} #1}\nobreak\hfil \nobreak\hbox to\@pnumwidth{\hss {\normalfont\itshape page\/} {#2}}\par%
   \global\AJW@firstTOCentryfalse%
  \else%
   \noindent\unskip{\normalfont\fontspec{FrutigerLTStd-BoldCn.otf}#1}\nobreak\hfil \nobreak\hbox to\@pnumwidth{\hss {#2}}\par%
  \fi%
 \endgroup%
 \vspace*{6.5pt}
}

\newcommand*\l@author[2]{\pagebreak[3]
 \@tempdima \AJW@toclmarg
 \begingroup
  \parindent 0pc%\z@
    \rightskip \@pnumwidth  \parfillskip -\@pnumwidth
  \leavevmode
  \ifAJW@firstTOCentry
   \noindent{\tocauthorfont #1}\nobreak\hfil \nobreak\hbox to\@pnumwidth{\hss {\normalfont\itshape page\/} }\par% #2
   \global\AJW@firstTOCentryfalse
  \else
   \noindent{\tocauthorfont #1}\nobreak\hfil \nobreak\hbox to\@pnumwidth{\hss }\par%#2
  \fi
  \vskip6.5pt
 \endgroup
}

\newcommand*\l@schapter[2]{\pagebreak[3]% now indented
 \@tempdima \z@
 \begingroup
  \parindent \z@
    \rightskip \@pnumwidth  \parfillskip -\@pnumwidth
  \leavevmode
  \advance \leftskip \@tempdima  \hskip -\leftskip
  \ifAJW@firstTOCentry
   {\itshape #1}\nobreak\hfil \nobreak\hbox to\@pnumwidth{\hss {\itshape page\/} #2}\par
   \global\AJW@firstTOCentryfalse
  \else
   {\itshape #1}\nobreak\hfil \nobreak\hbox to\@pnumwidth{\hss #2}\par
  \fi
 \endgroup
}

\newcommand*\l@sschapter[2]{\pagebreak[3]% now indented
 \vspace{\baselineskip}%
 \@tempdima \z@
 \begingroup
  \parindent \z@
    \rightskip \@pnumwidth  \parfillskip -\@pnumwidth
  \leavevmode
  \advance \leftskip \@tempdima  \hskip -\leftskip
  \ifAJW@firstTOCentry
   {\normalfont #1}\nobreak\hfil \nobreak\hbox to\@pnumwidth{\hss {\itshape page\/} #2}\par
   \global\AJW@firstTOCentryfalse
  \else
   {\normalfont #1}\nobreak\hfil \nobreak\hbox to\@pnumwidth{\hss #2}\par
  \fi
 \endgroup
}

% remove page number from contributor page
\newcommand*\l@contrib[2]{\pagebreak[3]
 \@tempdima \z@%
 \begingroup
  \parindent \z@  \raggedright
  \leavevmode
  \advance \leftskip \@tempdima  \hskip -\leftskip
  \ifAJW@firstTOCentry
   {#1}\nobreak\hfil \nobreak\hbox to\@pnumwidth{\hss {\itshape page\/} #2}\par
   \global\AJW@firstTOCentryfalse
  \else
   {#1}\nobreak\hfil \nobreak\hbox to\@pnumwidth{\hss }\par
  \fi
 \endgroup
}
%
\def\l@section#1#2{\addpenalty{-\@highpenalty}
\ifnum\c@tocdepth >0%
\@tempdima \@sectmax%
%\advance\@tempdima by 7pt%%7pt%
 \calctocindent%
 \begingroup%
 \parindent \z@ \rightskip \@tocrmarg%
 \advance\rightskip by \z@ \@plus 2cm%
 \advance\leftskip\@tempdima
 \advance\leftskip -9pt
 \pretolerance=10000%
 \parfillskip -\@tocrmarg%
 \leavevmode%
\hangindent\@sectmax%
 {\tocsecfont#1}\nobreak%
    \ifx0#2\hfil\null%
    \else%
        \hfill\nobreak\hbox to\@pnumwidth{\hss\tocsecpagefont{#2}}%
    \fi%
 \par%
 \penalty\@highpenalty \endgroup
\fi}
%
\def\l@subsection#1#2{\addpenalty{-\@highpenalty}
\ifnum\c@tocdepth >\@ne%
\@tempdima \@subsectmax\advance\@tempdima by 0pt%%7pt
 \calctocindent
 \begingroup
 \parindent \z@ \rightskip \@tocrmarg \advance\rightskip by \z@ \@plus 2cm
 \pretolerance=10000
 \parfillskip -\@tocrmarg
\leavevmode%
\advance\leftskip\@sectmax
\hangindent\@subsectmax%
{\tocsubsecfont#1}\nobreak
    \ifx0#2\hfil\null
    \else
        \hfill\nobreak\hbox to\@pnumwidth{\hss\tocsubsecpagefont#2}%
    \fi
 \par
 \penalty\@highpenalty \endgroup
\fi }
%
\newif\ifAJW@firstLOTentry\AJW@firstLOTentryfalse
\newif\ifAJW@firstLOFentry\AJW@firstLOFentryfalse

% listing for figures (repeat of schapter)
\newcommand*\l@figure[2]{\pagebreak[3]
 \@tempdima 19pt%\AJW@toclmarg
\tocfloatfont
 \begingroup
  \parindent \z@  \rightskip \@pnumwidth  \parfillskip -\@pnumwidth
  \leavevmode
  \advance \leftskip \@tempdima  \hskip -\leftskip
%
  \ifAJW@firstLOFentry
    {\tocfloatfont#1}\nobreak\hfil \nobreak\hbox to\@pnumwidth{\hss {\tocfloatfont\itshape page\/} #2\par}\par
    \global\AJW@firstLOFentrytrue
  \else
      \global\AJW@firstLOFentryfalse
    {\tocfloatfont#1}\nobreak\hfil \nobreak\hbox to\@pnumwidth{\hss\tocfloatfont #2\par}\par
  \fi
%
 \endgroup
}

\newcommand*\l@table[2]{\pagebreak[3]
 \@tempdima 19pt%\AJW@toclmarg
\tocfloatfont
 \begingroup
  \parindent \z@  \rightskip \@pnumwidth  \parfillskip -\@pnumwidth
  \leavevmode
  \advance \leftskip \@tempdima  \hskip -\leftskip
%
  \ifAJW@firstLOTentry
    {\tocfloatfont#1}\nobreak\hfil \nobreak\hbox to\@pnumwidth{\hss {\tocfloatfont\itshape page\/} #2\par}\par
    \global\AJW@firstLOTentrytrue
  \else
  \AJW@firstLOTentryfalse
    {\tocfloatfont#1}\nobreak\hfil \nobreak\hbox to\@pnumwidth{\hss\tocfloatfont #2\par}\par
  \fi
%
 \endgroup
}
