%%%%Half-title%
\def\makehalftitle{\thispagestyle{empty}%
\pagenumbering{roman}%
\ifx\@halftitle\empty\else\vspace*{12pt}\noindent{\HTfont\@halftitle\par\vspace*{7.5pt}}\fi%
\ifx\@halfsubtitle\empty\else\noindent{\HTsubfont\@halfsubtitle\vskip5pt\par}\fi%
\vspace*{20pt}%
\@afterheading\@afterindentfalse}%%

\def\authorname#1{\par\vspace*{13pt}\noindent{\fontspec{FrutigerLTStd-BoldCn.otf} #1}}

%%%%Title-page%

\def\edition#1{\gdef\@edition{\uppercase{\trackten{#1}}}}\edition{}
\def\titleeditionfont{\fontspec{FrutigerLTStd-Cn.otf}\fontsize{14}{16}\selectfont\selectfont}
\def\edition#1{\gdef\@edition{\uppercase{\trackten{#1}}}}\edition{}
\def\subtitle#1{\gdef\@fullsubtitle{#1}}\subtitle{}
\def\FTauthor#1{\gdef\@FTauthor{#1}}\FTauthor{}
\def\FTaffiliation#1{\gdef\@FTaffiliation{#1}}\FTaffiliation{}


\def\booktitle#1{\gdef\@fulltitle{#1}}\booktitle{}
\def\booksubtitle#1{\gdef\@fullsubtitle{#1}}\booksubtitle{}
\def\bookauthor#1{\gdef\@FTauthor{#1}}\bookauthor{}
\def\bookaffiliation#1{\gdef\@FTaffiliation{#1}}\bookaffiliation{}

\newcount\authorcount \authorcount0%
\newcount\tempauthorcount\tempauthorcount0%
\newcount\affilcount \affilcount0%
\newcount\tempcount%
%
\def\bookauthor#1{%
   \gdef\au@data{yes}%
   \expandafter\protected@xdef\csname author\the\authorcount\endcsname{\titleauthorfont#1}%
   \global\advance\authorcount1%
}
%
\def\bookaffiliation#1{%
   \expandafter\protected@xdef\csname affil\the\affilcount\endcsname{#1}%
   \global\advance\affilcount1%
}
\def\bookauthor#1{%
   \gdef\au@data{yes}%
   \expandafter\protected@xdef\csname author\the\authorcount\endcsname{\FTauthorfont#1}%
   \global\advance\authorcount2%
}
%
\def\bookaffiliation#1{%
   \expandafter\protected@xdef\csname affil\the\affilcount\endcsname{#1}%
   \global\advance\affilcount2%
}
\def\bookauthor#1{%
   \gdef\au@data{yes}%
   \expandafter\protected@xdef\csname author\the\authorcount\endcsname{\FTauthorfont#1}%
   \global\advance\authorcount3%
}
%
\def\bookaffiliation#1{%
   \expandafter\protected@xdef\csname affil\the\affilcount\endcsname{#1}%
   \global\advance\affilcount3%
}

%
\def\printauthor{%
   \global\tempauthorcount\authorcount%
   \global\advance\tempauthorcount-1%
   \ifnum\authorcount>0%
      \@whilenum\tempcount<\tempauthorcount%
        \do{%\vskip8pt
     		 \noindent{\FTauthorfont\csname author\the\tempcount\endcsname\par}\vskip0pt%
     		 \noindent{\FTaffilfont\csname affil\the\tempcount\endcsname}\vskip1.5pt%
            \global\advance\tempcount1}%
  		 \noindent{\FTauthorfont\csname author\the\tempcount\endcsname\par}\vskip0pt%
  		 \noindent{\FTaffilfont\csname affil\the\tempcount\endcsname\par}\vskip-12pt%
   \fi%
}


\def\makefulltitle{\thispagestyle{empty}%
\ifx\@fulltitle\empty\else\vspace*{-3pt}\noindent{\FTfont\@fulltitle\par}\vskip4pt\fi%
\ifx\@fullsubtitle\empty\else\vspace*{2.5pt}\noindent{\FTsubfont\@fullsubtitle\par}\fi%
\ifx\@edition\vspace*{-16pt}\empty\else\vspace*{17pt}\noindent{\titleeditionfont\@edition\par}\vskip4pt\fi%
{\color{scolor}\chaprule}\par
\ifx\printauthor\undefined\else\vskip30pt\noindent{\printauthor\par\vskip-4pt}\fi%
\vfill%
%
\titlepagelogo}
%
\newenvironment{copyrightpage}{\parindent0pt\vspace*{-15pt}%
\fontsize{8}{10}\selectfont}{\par}

\def\pauthor#1{{\textsf{\textbf{{#1}}}}}

